# Makefile for building and running tests for Siters (MuPDF backend)
# Usage: make -f Makefile.tests target

CC?=gcc
DATADIR ?= $(shell pwd)

PKG_CFLAGS := $(shell pkg-config --cflags gtk+-3.0 cmocka json-glib-1.0)
PKG_LIBS := $(shell pkg-config --libs gtk+-3.0 cmocka json-glib-1.0)
MUPDF_CFLAGS := $(shell pkg-config --cflags mupdf)
MUPDF_LIBS   := $(shell pkg-config --libs --static mupdf)

ORDERED_LIBS = $(MUPDF_LIBS) $(PKG_LIBS)

CFLAGS=-Wall -Wextra -Werror -g -DDATADIR=\"$(DATADIR)\" \
       -Iinclude -Iinclude/json-glib -Isrc \
       $(PKG_CFLAGS) $(MUPDF_CFLAGS)
LIBS=$(ORDERED_LIBS)

# Main application
SITERS_SRC=src/main.c src/siters.c src/log.c src/sessions_model.c src/session_model.c \
           src/document_model.c src/pdf_mupdf.c src/glibc_compat.c
SITERS_TARGET=siters

# Unit tests
UNIT_TEST_SRC=tests/test_siters_unit.c src/sessions_model.c src/session_model.c \
              src/document_model.c src/pdf_mupdf.c src/glibc_compat.c src/log.c
UNIT_TEST_TARGET=test_siters_unit

# GUI tests
GUI_TEST_SRC=tests/test_siters_gui.py

.PHONY: all build-app build-unit-tests run-unit-tests run-gui-tests clean help

all: build-app build-unit-tests help

build-app:
	@echo "Building Siters application..."
	$(CC) $(CFLAGS) -o $(SITERS_TARGET) $(SITERS_SRC) $(LIBS) \
		-Wl,--wrap=fmodf \
		-Wl,--wrap=fmod

build-unit-tests:
	@echo "Building unit tests..."
	$(CC) $(CFLAGS) -o $(UNIT_TEST_TARGET) $(UNIT_TEST_SRC) $(LIBS) \
		-Wl,--wrap=fmodf \
		-Wl,--wrap=fmod \
		-Wl,--wrap=gtk_window_new \
		-Wl,--wrap=gtk_window_set_title \
		-Wl,--wrap=gtk_window_set_default_size \
		-Wl,--wrap=g_signal_connect_data \
		-Wl,--wrap=gtk_window_set_geometry_hints \
		-Wl,--wrap=gtk_widget_get_allocation \
		-Wl,--wrap=gtk_range_get_adjustment \
		-Wl,--wrap=gtk_adjustment_get_value \
		-Wl,--wrap=gtk_scrolled_window_get_vadjustment

run-unit-tests: build-unit-tests
	@echo "Running unit tests..."
	./$(UNIT_TEST_TARGET)

run-gui-tests: build-app
	@echo "======================================"
	@echo "GUI Tests (Dogtail)"
	@echo "======================================"
	@echo ""
	@echo "Running GUI tests..."
	@echo "These tests verify basic app functionality"
	@echo "without relying on full AT-SPI accessibility."
	@echo ""
	@python3 tests/test_siters_gui.py

test: run-unit-tests
	@echo "Unit tests completed."
	@echo ""
	@echo "To run GUI tests, use: make -f Makefile.tests run-gui-tests"

clean:
	@echo "Cleaning up..."
	rm -f $(SITERS_TARGET)
	rm -f $(UNIT_TEST_TARGET)
	rm -f *.o

help:
	@echo "Siters Test Suite (MuPDF backend)"
	@echo "=================================="
	@echo ""
	@echo "Available targets:"
	@echo "  make -f Makefile.tests build-app        - Build the main application"
	@echo "  make -f Makefile.tests build-unit-tests - Build unit tests"
	@echo "  make -f Makefile.tests run-unit-tests   - Build and run unit tests (CMocka)"
	@echo "  make -f Makefile.tests run-gui-tests    - Build app and run GUI tests (Dogtail)"
	@echo "  make -f Makefile.tests test             - Run unit tests"
	@echo "  make -f Makefile.tests clean            - Remove built files"
	@echo ""
	@echo "Dependencies:"
	@echo "  - CMocka: pkg-config cmocka"
	@echo "  - GTK+3: pkg-config gtk+-3.0"
	@echo "  - MuPDF dev libs: set MUPDF_DIR (default /tmp/opencode/mupdf)"
